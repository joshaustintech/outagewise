<% content_for :title, "Dashboard | OutageWise" %>

<div class="grid gap-6 lg:grid-cols-[1fr_18rem]">
  <section class="space-y-5">
    <div>
      <p class="text-sm font-medium uppercase text-base-content/60">Local product skeleton</p>
      <h1 class="mt-2 text-3xl font-semibold">Dashboard</h1>
      <p class="mt-3 max-w-2xl text-base-content/75">
        The demo account is ready for monitor setup, status publishing, and
        later check-run history.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-lg border border-base-300 bg-base-100 p-5">
        <h2 class="text-lg font-semibold">Account</h2>
        <% if current_account %>
          <p class="mt-3 text-2xl font-semibold"><%= current_account.name %></p>
          <p class="mt-1 text-sm text-base-content/65"><%= current_user&.email || "No demo user configured" %></p>
        <% else %>
          <p class="mt-3 text-base-content/70">No demo account is available yet.</p>
        <% end %>
      </article>

      <article class="rounded-lg border border-base-300 bg-base-100 p-5">
        <h2 class="text-lg font-semibold">Customer database</h2>
        <% if current_account&.customer_database %>
          <p class="mt-3 text-sm text-base-content/70"><%= current_account.customer_database.label %></p>
          <p class="mt-2 break-words font-mono text-sm"><%= current_account.customer_database.database_path %></p>
        <% else %>
          <p class="mt-3 text-base-content/70">No customer database is registered yet.</p>
        <% end %>
      </article>
    </div>
  </section>

  <aside class="rounded-lg border border-base-300 bg-base-100 p-5">
    <h2 class="text-lg font-semibold">Frontend check</h2>
    <p class="mt-2 text-sm text-base-content/70">
      This small Elm widget is mounted inside a Rails-rendered page.
    </p>
    <div
      class="mt-4"
      data-elm-status-pulse
      data-account-name="<%= current_account&.name || "No account" %>">
    </div>
  </aside>
</div>

